# CarbonWise Environment Configuration (Example)
# Copy this file to .env and fill in the values

# ─── SERVER CONFIGURATION (For Render or similar backend hosts) ───

# Port for the backend server
PORT=3001

# Environment mode (development / production)
NODE_ENV=production

# JWT Secret — Generate a strong, random 64+ character string for production!
# e.g., run `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_with_a_secure_production_secret

# JWT token expiry
JWT_EXPIRES_IN=7d

# Database file path (relative to server directory)
# Note: On ephemeral hosts like Render (free tier), SQLite will be wiped on restart
# unless you mount a persistent disk and map DB_PATH to it.
DB_PATH=./data/carbonwise.db

# Allowed CORS Origins (Important for connecting Frontend to Backend)
# For local dev: http://localhost:3000
# For production: Add your Vercel URL here (e.g., https://carbonwise.vercel.app)
FRONTEND_URL=http://localhost:3000
# Fallback if FRONTEND_URL isn't set
CLIENT_URL=http://localhost:3000


# ─── FRONTEND CONFIGURATION (For Vercel) ───

# The Next.js frontend needs to know where the backend API lives.
# In Vercel, set this to your Render backend URL (e.g., https://carbonwise-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:3001
